{
  "name": "pwa-staff",
  "version": "1.0.0",
  "description": "Service worker and PWA registration for Rocket Craft",
  "main": "worker.js",
  "scripts": {
    "start": "local-web-server --port 3000",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "build:css": "postcss css/style.css -o dist/style.css",
    "build": "npm run build:css && npm run build:ts",
    "build:ts": "esbuild src/*.ts --bundle --outdir=dist && esbuild worker.ts --outfile=worker.js && esbuild cache.ts --outfile=cache.js"
  },
  "keywords": [
    "pwa",
    "service-worker",
    "unreal-engine"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@noble/hashes": "^2.2.0",
    "@playwright/test": "^1.61.0",
    "@rolldown/binding-darwin-arm64": "^1.1.1",
    "@types/node": "^25.9.3",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@wasm4pm/contracts": "file:../../wasm4pm/packages/contracts",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "local-web-server": "^5.3.0",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.15",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.8.4",
    "std-env": "^3.10.0",
    "typescript": "^6.0.3",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "axios": "^1.18.0"
  }
}
