#!/bin/bash
# rocket - Unified Rocket Craft Management Tool (Rust Wrapper)

set -e

PROJECT_ROOT="$(cd "$(dirname "$0")" && pwd)"
BIN_PATH="$PROJECT_ROOT/tools/target/release/rocket-cmd"

# Build the tool if it doesn't exist
if [ ! -f "$BIN_PATH" ]; then
    echo "Building Rocket Craft tools (release)..."
    cd "$PROJECT_ROOT/tools/rocket-cmd" && cargo build --release > /dev/null
    cd "$PROJECT_ROOT"
fi

# Pass all arguments to the Rust binary
exec "$BIN_PATH" "$@"
