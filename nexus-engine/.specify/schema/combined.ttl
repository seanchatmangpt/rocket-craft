    rdfs:comment "A phase in the main experience loops" .

gn:PlanetDimension a rdfs:Class ;
    rdfs:label "PlanetDimension" ;
    rdfs:comment "A value dimension of planetary intelligence" .

gn:MythologyArchetype a rdfs:Class ;
    rdfs:label "MythologyArchetype" ;
    rdfs:comment "An archetype in civilization myths" .

