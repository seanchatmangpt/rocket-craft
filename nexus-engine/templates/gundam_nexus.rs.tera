{% for row in results %}
{% if row.name != "Walking" and row.name != "Flight" and row.name != "Hover" and row.name != "Space" and row.name != "Aquatic" %}
#[derive(Debug, Clone, Copy, PartialEq, Eq, Default)]
pub struct {{ row.name }};

impl OntologyName for {{ row.name }} {
    fn ontology_name() -> &'static str {
        "{{ row.name }}"
    }
}

