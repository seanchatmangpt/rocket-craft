// Mobility Default implementations — lore-grounded from UC Gundam tech manuals.
// Physical quantities use QUDT 2.1 units (https://qudt.org/).
// Source of truth: nexus-engine/.specify/schema/gundam_nexus.ttl

use crate::generated_gundam::{Mobility, Walking, Flight, Hover, Aquatic, Space};
use crate::generated_gundam::AABB;

{% for row in results %}
{% if row.name == "Walking" %}
impl Default for Mobility {
    /// Canonical baseline: RX-78-2 Gundam (UC 0079) bipedal locomotion.
    /// mass={{ row.mass_kg | default(value="60000") }} kg (QUDT unit:KiloGM)
    /// max_speed={{ row.max_speed_ms | default(value="45.83") }} m/s = 165 km/h (QUDT unit:M-PER-SEC)
    fn default() -> Self {
        Self {
            id: "mobility-default".to_string(),
            mass: {{ row.mass_kg | default(value="60000") }}_f32,
            occupancy: AABB::default(),
            clearance: AABB::default(),
            load_capacity: {{ row.load_capacity_kg | default(value="55000") }}_f32,
            max_speed: {{ row.max_speed_ms | default(value="45.83") }}_f32,
        }
    }
}

impl Default for Walking {
    /// Canonical bipedal walking: RX-78-2 Gundam (2 legs, 165 km/h ground speed)
    fn default() -> Self {
        Self {
            physical: Mobility::default(),
            leg_count: {{ row.leg_count | default(value="2") }},
        }
    }
}
{% endif %}
{% if row.name == "Flight" %}
impl Default for Flight {
    /// Canonical flight: Wing Gundam (AC 195) — 7,150 kg, Mach 1+, 14.4m wing span
    fn default() -> Self {
        Self {
            physical: Mobility {
                id: "flight-mobility".to_string(),
                mass: {{ row.mass_kg | default(value="7150") }}_f32,
                occupancy: AABB::default(),
                clearance: AABB::default(),
                load_capacity: {{ row.load_capacity_kg | default(value="4000") }}_f32,
                max_speed: {{ row.max_speed_ms | default(value="340") }}_f32,
            },
            wing_span: {{ row.wing_span_m | default(value="14.4") }}_f32,
        }
    }
}
{% endif %}
