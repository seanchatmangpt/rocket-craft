# =============================================================================
# Rocket Craft — Environment Variables Reference
# Copy this file to .env and fill in your values.
# .env is gitignored; never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Unreal Engine 4 (required for UE4 builds, html5 pipeline, and rocket doctor)
# Set to the root of your UE4.24 source / binary install.
# -----------------------------------------------------------------------------
UE4_ROOT=/path/to/UnrealEngine

# -----------------------------------------------------------------------------
# Blender (optional — only required by the asset-pipeline worktree)
# macOS default shown; Linux is usually just `blender` on PATH.
# -----------------------------------------------------------------------------
BLENDER_PATH=/Applications/Blender.app/Contents/MacOS/blender

# -----------------------------------------------------------------------------
# Supabase — production / cloud
# Obtain these from your Supabase project dashboard → Settings → API.
# Used by: pwa-staff/src/lib/supabaseClient.ts
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Supabase service-role key — server-side only, NEVER expose to the browser.
# Used by CI (nuxt-shell headless loop) and any server-side Supabase admin calls.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Supabase — local Docker / supabase CLI  (`supabase start`)
# These are the defaults created by `supabase init`; safe to commit as-is.
# Override SUPABASE_URL / SUPABASE_ANON_KEY above when targeting local dev.
# Local URL: http://127.0.0.1:54321  (already the fallback in supabaseClient.ts)
# Local anon key (also hardcoded as fallback): sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=postgres

# -----------------------------------------------------------------------------
# Node / PWA
# NODE_ENV controls build optimisations in esbuild and Nuxt.
# -----------------------------------------------------------------------------
NODE_ENV=production

# -----------------------------------------------------------------------------
# Rocket CLI
# ROCKET_CLOUD=1  — skip UE4/Blender doctor checks (useful in cloud/CI envs
#                   where UE4 is not installed).
# CI=true         — detected automatically by GitHub Actions; triggers auto-build
#                   of rocket-cmd if the binary is missing.
# -----------------------------------------------------------------------------
ROCKET_CLOUD=
CI=

# -----------------------------------------------------------------------------
# Android (optional — only for Android platform builds)
# -----------------------------------------------------------------------------
# ANDROID_HOME=/path/to/android-sdk
# ANDROID_NDK_HOME=/path/to/android-ndk

# -----------------------------------------------------------------------------
# HTML5 pipeline (optional overrides)
# Defaults are sensible; only set these if you need non-standard paths.
# -----------------------------------------------------------------------------
# HTML5_ARCHIVE_DIR=/tmp/brm-html5-archive
# HTML5_SERVE_PORT=8080
