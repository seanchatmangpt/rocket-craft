# ── Supabase ──────────────────────────────────────────────────────────────────
# Local dev defaults (supabase start). Copy to .env and fill in non-local values.
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH
# Service role key: required for server-side endpoints (leaderboard, receipts, etc.)
# Run: supabase status  →  copy "service_role key"
SUPABASE_SERVICE_ROLE_KEY=

# ── Ed25519 Receipt Signing ────────────────────────────────────────────────────
# Generate with: rocket supabase keygen
# ROCKET_SIGNING_KEY   — private key for signing cook receipts (rocket html5 verify)
# ROCKET_SIGNING_PUBKEY — public key for browser + server verify-signature endpoint
# Both are base64-encoded Ed25519 keys. Never commit the private key.
ROCKET_SIGNING_KEY=
ROCKET_SIGNING_PUBKEY=

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
# OTLP HTTP endpoint for cook pipeline spans.
# Local Jaeger: docker run -p 4318:4318 -p 16686:16686 jaegertracing/all-in-one
OTLP_COLLECTOR_URL=http://localhost:4318

# ── Headless / CI ─────────────────────────────────────────────────────────────
# Allow POST /api/game/session-seed in non-test environments (set to 1 for CI)
# Defaults to allowed in NODE_ENV=development or NODE_ENV=test automatically.
ALLOW_SESSION_SEED=

# Test runner base URL (used by vitest integration tests when MOCK_API is not set)
API_BASE_URL=http://localhost:3000
