#usda 1.0
(
    defaultPrim = "Head"
    upAxis = "Y"
    metersPerUnit = 1.0
)

def Xform "Head" (
    kind = "component"
)
{
    kind = "component"
)
{
    double3 xformOp:translate = (0, 2.5, 0)
    uniform token[] xformOpOrder = ["xformOp:translate"]

    def Cube "Cranium"
    {
        double3 xformOp:scale = (0.6, 0.8, 0.7)
        color3f[] primvars:displayColor = [(0.9, 0.9, 0.9)]
        uniform token[] xformOpOrder = ["xformOp:scale"]
    }
    def Cone "VFinLeft"
    {
        double radius = 0.1
        double height = 1.2
        double3 xformOp:translate = (-0.4, 0.5, 0.6)
        double3 xformOp:rotateXYZ = (30, 0, -45)
        color3f[] primvars:displayColor = [(0.9, 0.7, 0.1)]
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
    }
    def Cone "VFinRight"
    {
        double radius = 0.1
        double height = 1.2
        double3 xformOp:translate = (0.4, 0.5, 0.6)
        double3 xformOp:rotateXYZ = (30, 0, 45)
        color3f[] primvars:displayColor = [(0.9, 0.7, 0.1)]
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
    }
}
