#usda 1.0
(
    defaultPrim = "RightLeg"
    upAxis = "Y"
    metersPerUnit = 1.0
)

def Xform "RightLeg" (
    kind = "component"
)
{
    kind = "component"
)
{
    double3 xformOp:translate = (1.0, -2.5, 0)
    double3 xformOp:rotateXYZ = (10, 0, -10)
    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]

    def Cylinder "Thigh"
    {
        double radius = 0.6
        double height = 3.0
        double3 xformOp:translate = (0, -1.5, 0)
        color3f[] primvars:displayColor = [(0.9, 0.9, 0.9)]
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
    def Cylinder "Calf"
    {
        double radius = 0.8
        double height = 4.0
        double3 xformOp:translate = (0, -5.0, 0)
        color3f[] primvars:displayColor = [(0.85, 0.85, 0.85)]
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
}
