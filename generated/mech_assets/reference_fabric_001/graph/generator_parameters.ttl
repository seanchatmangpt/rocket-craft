mud:prim_0001 rdf:type mud:GeometryPrimitive ;
    mud:belongsToPart mud:torso_core ;
    mud:primitiveFamily "tapered_box" ;
    mud:translateX "0.0000"^^xsd:float ;
    mud:translateY "0.0000"^^xsd:float ;
    mud:translateZ "100.0000"^^xsd:float ;
    mud:scaleX "20.0000"^^xsd:float ;
    mud:scaleY "18.0000"^^xsd:float ;
    mud:scaleZ "2.0000"^^xsd:float ;
    mud:rotateX "0.0000"^^xsd:float ;
    mud:rotateY "0.0000"^^xsd:float ;
    mud:rotateZ "0.0000"^^xsd:float ;
