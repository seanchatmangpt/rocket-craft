#usda 1.0
(
    defaultPrim = "ASSET_ReferenceFabric_001"
    upAxis = "Y"
    metersPerUnit = 0.01
)

def Xform "ASSET_ReferenceFabric_001"
{
    # Assembly pose. The part files are authored in a local "body frame" where
    # X = left/right, Y = front/back depth, and Z = vertical body height (feet at
    # low Z, head at high Z). The scene uses upAxis = "Y", so rotate the whole
    # assembly +90 deg about X to stand the body's +Z height axis up along world
    # +Y, producing an upright, front-facing mech rather than a top-down scatter.
    # Per-part translate/scale below (applied in the local body frame, before this
    # rotation) pull the widely-scattered wings, blades and limbs inward and up so
    # the parts compose into one dense, compact silhouette that fills its bounding
    # box instead of leaving large empty gaps.
    double3 xformOp:rotateXYZ = (90, 0, 0)
    uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]
    def Xform "Torso" (
        prepend references = @./SM_Torso.usda@
    )
    {
    }

    def Xform "Head" (
        prepend references = @./SM_Head.usda@
    )
    {
    }

    # Wings: pull inward in X toward the torso centerline and lift in Z so the
    # feather array rises behind the shoulders instead of drooping wide.
    def Xform "Wing_Left" (
        prepend references = @./SM_WingArray_Left.usda@
    )
    {
        double3 xformOp:translate = (12, -6, 8)
        double3 xformOp:scale = (0.45, 1.0, 0.7)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
    }

    def Xform "Wing_Right" (
        prepend references = @./SM_WingArray_Right.usda@
    )
    {
        double3 xformOp:translate = (-12, -6, 8)
        double3 xformOp:scale = (0.45, 1.0, 0.7)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
    }

    # Blades: pull inward toward the body and shorten so they stop reading as
    # isolated thin spikes far from the silhouette mass.
    def Xform "Blade_Left" (
        prepend references = @./SM_Blade_Left.usda@
    )
    {
        double3 xformOp:translate = (12, 0, 25)
        double3 xformOp:scale = (0.5, 0.5, 0.6)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
    }

    def Xform "Blade_Right" (
        prepend references = @./SM_Blade_Right.usda@
    )
    {
        double3 xformOp:translate = (-12, 0, 25)
        double3 xformOp:scale = (0.5, 0.5, 0.6)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
    }

    # Limbs: tuck inward against the torso so arms/legs hug the body mass.
    def Xform "Limb_Left" (
        prepend references = @./SM_Limb_Left.usda@
    )
    {
        double3 xformOp:translate = (6, 0, 10)
        double3 xformOp:scale = (0.5, 1.0, 0.8)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
    }

    def Xform "Limb_Right" (
        prepend references = @./SM_Limb_Right.usda@
    )
    {
        double3 xformOp:translate = (-6, 0, 10)
        double3 xformOp:scale = (0.5, 1.0, 0.8)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
    }

    # Loadout (backpack/thrusters): lift up behind the torso and compress its
    # vertical extent so it tucks against the body instead of hanging far below.
    def Xform "Loadout" (
        prepend references = @./SM_Loadout.usda@
    )
    {
        double3 xformOp:translate = (0, 4, 15)
        double3 xformOp:scale = (0.7, 1.0, 0.6)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
    }

    def Scope "Materials"
    {
        {% for row in results %}
        def Material "{{ row.materialLocalName }}" (
            prepend references = @../materialx/{{ row.materialLocalName }}.mtlx@
        )
        {
        }
        {% endfor %}
    }
}
