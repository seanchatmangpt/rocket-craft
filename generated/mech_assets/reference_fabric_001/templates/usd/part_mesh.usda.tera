#usda 1.0
(
{% set has_torso = false %}
{% set has_head = false %}
{% set has_wing_left = false %}
{% set has_wing_right = false %}
{% set has_blade_left = false %}
{% set has_blade_right = false %}
{% set has_limb_left = false %}
{% set has_limb_right = false %}
{% set has_loadout = false %}

{% for row in results %}
    {% if row.partLocalName == "torso_core" %}
        {% set_global has_torso = true %}
    {% elif row.partLocalName == "head_unit" or row.partLocalName == "v_fin_left" or row.partLocalName == "v_fin_right" %}
        {% set_global has_head = true %}
    {% elif row.partLocalName == "wing_root_left" or row.partLocalName == "primary_wing_feathers_left" or row.partLocalName == "secondary_wing_feathers_left" %}
        {% set_global has_wing_left = true %}
    {% elif row.partLocalName == "wing_root_right" or row.partLocalName == "primary_wing_feathers_right" or row.partLocalName == "secondary_wing_feathers_right" %}
        {% set_global has_wing_right = true %}
    {% elif row.partLocalName == "blade_left" %}
        {% set_global has_blade_left = true %}
    {% elif row.partLocalName == "blade_right" %}
        {% set_global has_blade_right = true %}
    {% elif row.partLocalName == "shoulder_left" or row.partLocalName == "arm_left" or row.partLocalName == "leg_left" %}
        {% set_global has_limb_left = true %}
    {% elif row.partLocalName == "shoulder_right" or row.partLocalName == "arm_right" or row.partLocalName == "leg_right" %}
        {% set_global has_limb_right = true %}
    {% elif row.partLocalName == "backpack_core" or row.partLocalName == "thruster_cluster" %}
        {% set_global has_loadout = true %}
    {% endif %}
{% endfor %}

{% if has_torso %}
    defaultPrim = "SM_Torso"
{% elif has_head %}
    defaultPrim = "SM_Head"
{% elif has_wing_left %}
    defaultPrim = "SM_WingArray_Left"
{% elif has_wing_right %}
    defaultPrim = "SM_WingArray_Right"
{% elif has_blade_left %}
    defaultPrim = "SM_Blade_Left"
{% elif has_blade_right %}
    defaultPrim = "SM_Blade_Right"
{% elif has_limb_left %}
    defaultPrim = "SM_Limb_Left"
{% elif has_limb_right %}
    defaultPrim = "SM_Limb_Right"
{% elif has_loadout %}
    defaultPrim = "SM_Loadout"
{% else %}
    defaultPrim = "SM_Unknown"
{% endif %}
    upAxis = "Y"
    metersPerUnit = 0.01
    doc = "Generated by ggen. Deterministic USD StaticMesh container."
)

{% macro render_primitive(row) %}
    {% if row.type == "socket" %}
        def Xform "{{ row.primLocalName }}"
        {
            double3 xformOp:translate = ({{ row.translateX }}, {{ row.translateY }}, {{ row.translateZ }})
            uniform token[] xformOpOrder = ["xformOp:translate"]
        }
    {% else %}
        def Xform "{{ row.primLocalName }}_group" (
            kind = "component"
        )
        {
            custom string owner_part_id = "{{ row.partLocalName }}"
            double3 xformOp:translate = ({{ row.translateX }}, {{ row.translateY }}, {{ row.translateZ }})
            double3 xformOp:scale = ({{ row.scaleX }}, {{ row.scaleY }}, {{ row.scaleZ }})
            double3 xformOp:rotateXYZ = ({{ row.rotateX }}, {{ row.rotateY }}, {{ row.rotateZ }})
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]

            {% if row.type == "angular_armor_shell" or row.type == "tapered_box" %}
                {% for i in range(end=16) %}
                def Cube "armor_plate_{{ i }}"
                {
                    custom string owner_part_id = "{{ row.partLocalName }}"
                    double size = 1.0
                    double3 xformOp:scale = ({{ 1.0 - (i * 0.025) }}, {{ 1.0 - (i * 0.025) }}, 0.06)
                    double3 xformOp:translate = (0.0, 0.0, {{ i * 0.04 }})
                    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
                    rel material:binding = </ASSET_ReferenceFabric_001/Materials/{{ row.materialLocalName }}>
                }
                def Cylinder "armor_piston_{{ i }}"
                {
                    custom string owner_part_id = "{{ row.partLocalName }}"
                    double radius = 0.05
                    double height = 1.2
                    double3 xformOp:translate = (0.4, 0.4, {{ i * 0.04 }})
                    uniform token[] xformOpOrder = ["xformOp:translate"]
                    rel material:binding = </ASSET_ReferenceFabric_001/Materials/M_DarkFrame>
                }
                def Cylinder "armor_piston2_{{ i }}"
                {
                    custom string owner_part_id = "{{ row.partLocalName }}"
                    double radius = 0.05
                    double height = 1.2
                    double3 xformOp:translate = (-0.4, -0.4, {{ i * 0.04 }})
                    uniform token[] xformOpOrder = ["xformOp:translate"]
                    rel material:binding = </ASSET_ReferenceFabric_001/Materials/M_DarkFrame>
                }
                {% endfor %}
            {% elif row.type == "layered_swept_feather_panel" or row.type == "feather_panel" %}
                {% for i in range(end=24) %}
                def Cube "feather_blade_{{ i }}"
                {
                    custom string owner_part_id = "{{ row.partLocalName }}"
                    double size = 1.0
                    double3 xformOp:scale = ({{ 0.8 - (i * 0.025) }}, 0.04, {{ 1.5 - (i * 0.05) }})
                    double3 xformOp:translate = ({{ i * 0.05 }}, {{ i * 0.025 }}, 0.0)
                    double3 xformOp:rotateXYZ = (0, {{ i * 5.0 }}, 0)
                    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]
                    rel material:binding = </ASSET_ReferenceFabric_001/Materials/{{ row.materialLocalName }}>
                }
                def Cone "feather_tip_{{ i }}"
                {
                    custom string owner_part_id = "{{ row.partLocalName }}"
                    double radius = 0.2
                    double height = 0.5
                    double3 xformOp:translate = ({{ i * 0.05 }}, {{ i * 0.025 }}, 0.8)
                    uniform token[] xformOpOrder = ["xformOp:translate"]
                    rel material:binding = </ASSET_ReferenceFabric_001/Materials/M_CyanBlade>
                }
                {% endfor %}
            {% elif row.type == "beveled_hard_surface_plate" or row.type == "blade_prism" %}
                {% for i in range(end=10) %}
                def Cube "beveled_plate_{{ i }}"
                {
                    custom string owner_part_id = "{{ row.partLocalName }}"
                    double size = 1.0
                    double3 xformOp:scale = (0.6, 0.2, {{ 1.0 - (i * 0.075) }})
                    double3 xformOp:translate = (0.0, {{ i * 0.025 }}, 0.0)
                    double3 xformOp:rotateXYZ = ({{ i * 5.0 }}, 0, 0)
                    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]
                    rel material:binding = </ASSET_ReferenceFabric_001/Materials/{{ row.materialLocalName }}>
                }
                def Capsule "blade_edge_{{ i }}"
                {
                    custom string owner_part_id = "{{ row.partLocalName }}"
                    double radius = 0.02
                    double height = 1.2
                    double3 xformOp:translate = (0.3, {{ i * 0.025 }}, 0.0)
                    uniform token[] xformOpOrder = ["xformOp:translate"]
                    rel material:binding = </ASSET_ReferenceFabric_001/Materials/M_CyanBlade>
                }
                {% endfor %}
            {% else %}
                {% for i in range(end=12) %}
                def Cylinder "subframe_core_{{ i }}"
                {
                    custom string owner_part_id = "{{ row.partLocalName }}"
                    double radius = {{ 0.3 - (i * 0.02) }}
                    double height = {{ 0.8 + (i * 0.05) }}
                    double3 xformOp:rotateXYZ = (90, 0, 0)
                    uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]
                    rel material:binding = </ASSET_ReferenceFabric_001/Materials/M_DarkFrame>
                }
                def Sphere "subframe_joint_{{ i }}"
                {
                    custom string owner_part_id = "{{ row.partLocalName }}"
                    double radius = 0.35
                    double3 xformOp:scale = (1.0, 0.5, 1.0)
                    double3 xformOp:translate = (0.0, {{ 0.4 + (i * 0.025) }}, 0.0)
                    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
                    rel material:binding = </ASSET_ReferenceFabric_001/Materials/{{ row.materialLocalName }}>
                }
                {% endfor %}
            {% endif %}
        }
    {% endif %}
{% endmacro %}

{% if has_torso %}
def Xform "SM_Torso"
{
    custom string owner_part_id = "SM_Torso"
    {% for row in results %}
        {% if row.partLocalName == "torso_core" %}
            {{ self::render_primitive(row=row) }}
        {% endif %}
    {% endfor %}
}
{% endif %}

{% if has_head %}
def Xform "SM_Head"
{
    custom string owner_part_id = "SM_Head"
    {% for row in results %}
        {% if row.partLocalName == "head_unit" or row.partLocalName == "v_fin_left" or row.partLocalName == "v_fin_right" %}
            {{ self::render_primitive(row=row) }}
        {% endif %}
    {% endfor %}
}
{% endif %}

{% if has_wing_left %}
def Xform "SM_WingArray_Left"
{
    custom string owner_part_id = "SM_WingArray_Left"
    {% for row in results %}
        {% if row.partLocalName == "wing_root_left" or row.partLocalName == "primary_wing_feathers_left" or row.partLocalName == "secondary_wing_feathers_left" %}
            {{ self::render_primitive(row=row) }}
        {% endif %}
    {% endfor %}
}
{% endif %}

{% if has_wing_right %}
def Xform "SM_WingArray_Right"
{
    custom string owner_part_id = "SM_WingArray_Right"
    {% for row in results %}
        {% if row.partLocalName == "wing_root_right" or row.partLocalName == "primary_wing_feathers_right" or row.partLocalName == "secondary_wing_feathers_right" %}
            {{ self::render_primitive(row=row) }}
        {% endif %}
    {% endfor %}
}
{% endif %}

{% if has_blade_left %}
def Xform "SM_Blade_Left"
{
    custom string owner_part_id = "SM_Blade_Left"
    {% for row in results %}
        {% if row.partLocalName == "blade_left" %}
            {{ self::render_primitive(row=row) }}
        {% endif %}
    {% endfor %}
}
{% endif %}

{% if has_blade_right %}
def Xform "SM_Blade_Right"
{
    custom string owner_part_id = "SM_Blade_Right"
    {% for row in results %}
        {% if row.partLocalName == "blade_right" %}
            {{ self::render_primitive(row=row) }}
        {% endif %}
    {% endfor %}
}
{% endif %}

{% if has_limb_left %}
def Xform "SM_Limb_Left"
{
    custom string owner_part_id = "SM_Limb_Left"
    {% for row in results %}
        {% if row.partLocalName == "shoulder_left" or row.partLocalName == "arm_left" or row.partLocalName == "leg_left" %}
            {{ self::render_primitive(row=row) }}
        {% endif %}
    {% endfor %}
}
{% endif %}

{% if has_limb_right %}
def Xform "SM_Limb_Right"
{
    custom string owner_part_id = "SM_Limb_Right"
    {% for row in results %}
        {% if row.partLocalName == "shoulder_right" or row.partLocalName == "arm_right" or row.partLocalName == "leg_right" %}
            {{ self::render_primitive(row=row) }}
        {% endif %}
    {% endfor %}
}
{% endif %}

{% if has_loadout %}
def Xform "SM_Loadout"
{
    custom string owner_part_id = "SM_Loadout"
    {% for row in results %}
        {% if row.partLocalName == "backpack_core" or row.partLocalName == "thruster_cluster" %}
            {{ self::render_primitive(row=row) }}
        {% endif %}
    {% endfor %}
}
{% endif %}
