// Generated by ggen - Walkthrough State Transitions
// This implements a branchless state transition table to comply with Combinatorial Maximalist Doctrine

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
#[repr(u8)]
pub enum WalkthroughState {
    {%- set unique_states = [] -%}
    {%- for row in results -%}
        {%- if row.current_state not in unique_states -%}
            {%- set_global unique_states = unique_states | concat(with=row.current_state) -%}
            {{ row.current_state }} = {{ loop.index0 }},
        {%- endif -%}
        {%- if row.next_state not in unique_states -%}
            {%- set_global unique_states = unique_states | concat(with=row.next_state) -%}
            {{ row.next_state }} = {{ loop.index0 + 100 }},
        {%- endif -%}
    {%- endfor %}
    Invalid = 255,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
#[repr(u8)]
pub enum InputEvent {
    {%- set unique_events = [] -%}
    {%- for row in results -%}
        {%- if row.input_event not in unique_events -%}
            {%- set_global unique_events = unique_events | concat(with=row.input_event) -%}
            {{ row.input_event }} = {{ loop.index0 }},
        {%- endif -%}
    {%- endfor %}
}

pub const WALKTHROUGH_TRANSITION_TABLE_SIZE: usize = 256;

// Flat 2D array for branchless lookup
pub static WALKTHROUGH_TRANSITIONS: [[u8; WALKTHROUGH_TRANSITION_TABLE_SIZE]; WALKTHROUGH_TRANSITION_TABLE_SIZE] = {
    let mut table = [[255; WALKTHROUGH_TRANSITION_TABLE_SIZE]; WALKTHROUGH_TRANSITION_TABLE_SIZE];
    {% for row in results %}
    table[WalkthroughState::{{ row.current_state }} as usize][InputEvent::{{ row.input_event }} as usize] = WalkthroughState::{{ row.next_state }} as u8;
    {% endfor %}
    table
};

#[inline(always)]
pub fn get_next_walkthrough_state(current: WalkthroughState, event: InputEvent) -> WalkthroughState {
    let next_val = WALKTHROUGH_TRANSITIONS[current as usize][event as usize];
    // We avoid branching using transmute because we statically know only valid states or 255 exist in table.
    // Assuming 255 is Invalid and we have a well-defined mapping.
    unsafe { std::mem::transmute(next_val) }
}
