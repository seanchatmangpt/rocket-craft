// Generated by ggen - Station Process Transitions
// Implements branchless state transitions.

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
#[repr(u8)]
pub enum StationState {
    {%- set unique_states = [] -%}
    {%- for row in results -%}
        {%- if row.station_state not in unique_states -%}
            {%- set_global unique_states = unique_states | concat(with=row.station_state) -%}
            {{ row.station_state }} = {{ loop.index0 }},
        {%- endif -%}
        {%- if row.next_station_state not in unique_states -%}
            {%- set_global unique_states = unique_states | concat(with=row.next_station_state) -%}
            {{ row.next_station_state }} = {{ loop.index0 + 100 }},
        {%- endif -%}
    {%- endfor %}
    Invalid = 255,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
#[repr(u8)]
pub enum PartState {
    {%- set unique_parts = [] -%}
    {%- for row in results -%}
        {%- if row.part_state not in unique_parts -%}
            {%- set_global unique_parts = unique_parts | concat(with=row.part_state) -%}
            {{ row.part_state }} = {{ loop.index0 }},
        {%- endif -%}
    {%- endfor %}
}

pub const STATION_TRANSITION_TABLE_SIZE: usize = 256;

// Branchless 2D lookup array
pub static STATION_TRANSITIONS: [[u8; STATION_TRANSITION_TABLE_SIZE]; STATION_TRANSITION_TABLE_SIZE] = {
    let mut table = [[255; STATION_TRANSITION_TABLE_SIZE]; STATION_TRANSITION_TABLE_SIZE];
    {% for row in results %}
    table[StationState::{{ row.station_state }} as usize][PartState::{{ row.part_state }} as usize] = StationState::{{ row.next_station_state }} as u8;
    {% endfor %}
    table
};

#[inline(always)]
pub fn get_next_station_state(current: StationState, part: PartState) -> StationState {
    let next_val = STATION_TRANSITIONS[current as usize][part as usize];
    unsafe { std::mem::transmute(next_val) }
}
