@prefix core: <http://rocket-craft.com/ontology/core#> .
@prefix mud: <http://rocket-craft.com/ontology/mud#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

mud:Spawn a mud:RouteNode .
mud:FactoryEntrance a mud:RouteNode .
mud:FrameAssembly a mud:RouteNode, mud:Station .
mud:SocketTopology a mud:RouteNode, mud:Station .
mud:ArmorSkinStation a mud:RouteNode, mud:Station .
mud:RigMotionStation a mud:RouteNode, mud:Station .
mud:VerificationGate a mud:RouteNode, mud:Station .
mud:ReceiptTerminal a mud:RouteNode, mud:Station .
mud:ExitOrLoop a mud:RouteNode .

mud:Frame a mud:PartFamily .
mud:Shoulder a mud:PartFamily .
mud:Arm a mud:PartFamily .
mud:Leg a mud:PartFamily .
mud:Socket a mud:PartFamily .
mud:ArmorPanel a mud:PartFamily .
mud:WeaponMount a mud:PartFamily .
mud:CoolingVent a mud:PartFamily .
mud:SkinLayer a mud:PartFamily .
mud:MotionFamily a mud:PartFamily .
mud:LODVariant a mud:PartFamily .
mud:ReceiptTerminalPart a mud:PartFamily .

mud:damage_class a mud:AuthorityField .
mud:heat_class a mud:AuthorityField .
mud:stress_class a mud:AuthorityField .
mud:grip_class a mud:AuthorityField .
mud:socket_health_class a mud:AuthorityField .
mud:lod_class a mud:AuthorityField .
mud:walkthrough_state_class a mud:AuthorityField .
mud:station_state_class a mud:AuthorityField .
mud:projection_state_class a mud:AuthorityField .
mud:receipt_state_class a mud:AuthorityField .

mud:REFUSED_MISSING_SOCKET a mud:RefusalReason .

# ---------------------------------------------------------
# Gap Checker Metamodel
# ---------------------------------------------------------
mud:ExpectedFile a owl:Class ;
    rdfs:label "Expected Generated File" ;
    rdfs:comment "A file artifact expected to be present in the build output." .

mud:GapCheckRule a owl:Class ;
    rdfs:label "Gap Check Rule" ;
    rdfs:comment "An execution check or condition that must pass to ensure no gaps." .

mud:filePath a owl:DatatypeProperty ;
    rdfs:domain mud:ExpectedFile ;
    rdfs:range xsd:string ;
    rdfs:label "File Path" .

mud:fileType a owl:DatatypeProperty ;
    rdfs:domain mud:ExpectedFile ;
    rdfs:range xsd:string ;
    rdfs:label "File Type" .

mud:checkId a owl:DatatypeProperty ;
    rdfs:domain mud:GapCheckRule ;
    rdfs:range xsd:string ;
    rdfs:label "Check ID" .

mud:checkDescription a owl:DatatypeProperty ;
    rdfs:domain mud:GapCheckRule ;
    rdfs:range xsd:string ;
    rdfs:label "Check Description" .

mud:checkType a owl:DatatypeProperty ;
    rdfs:domain mud:GapCheckRule ;
    rdfs:range xsd:string ;
    rdfs:label "Check Type" .

mud:checkCommand a owl:DatatypeProperty ;
    rdfs:domain mud:GapCheckRule ;
    rdfs:range xsd:string ;
    rdfs:label "Command Line String" .

