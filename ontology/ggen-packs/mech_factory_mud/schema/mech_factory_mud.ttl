# Expected File Instances
# ---------------------------------------------------------
# Rust outputs
mud:GenRustConstantsFile a mud:ExpectedFile ;
    mud:filePath "crates/mech_factory_mud/src/generated_constants.rs" ;
    mud:fileType "rust" ;
    rdfs:label "generated_constants.rs" .

