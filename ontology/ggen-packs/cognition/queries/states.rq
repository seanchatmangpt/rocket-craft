PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX ggen: <https://genesis.gg/ontology/ggen#>
PREFIX cog: <https://genesis.gg/ontology/cognition#>

SELECT ?state_name
WHERE {
  ?state a cog:CognitionState ;
         rdfs:label ?state_name .
}
ORDER BY ?state_name
