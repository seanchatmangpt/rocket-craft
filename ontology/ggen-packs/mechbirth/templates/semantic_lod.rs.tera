        let has_explicit = (v_miss >= 13) as u8 | (v_dmg >= 13) as u8 | (v_thr >= 13) as u8 | (v_proc >= 13) as u8;
        let crown_violation = is_crown & (1 - has_explicit);

        let refusal = out_of_bounds | crown_violation;

        outputs.lod_class[i] = class_disc;
        outputs.projection_priority[i] = proj_priority_lut[class_disc as usize];
        outputs.authority_required[i] = is_crown | is_primary;
