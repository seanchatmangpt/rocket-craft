pub fn batch_classify(inputs: &LodInputsSoA, outputs: &mut LodOutputSoA) {
    const MAX_CLASS: u8 = 15;
    
    // LUT for Projection Priority based on discriminant
    let mut proj_priority_lut = [0u8; 256];
{% for row in results %}
    proj_priority_lut[{{ row.discriminant }}] = {{ row.projectionPriority }};
{% endfor %}

    // Branchless tight loop for LLVM auto-vectorization
    for i in 0..BATCH_SIZE {
        let v_dist = inputs.distance_class[i];
        let v_miss = inputs.mission_relevance[i];
        let v_dmg = inputs.damage_class[i];
        let v_thr = inputs.threat_class[i];
        let v_int = inputs.interaction_probability[i];
        let v_proc = inputs.process_step_relevance[i];
        let v_pred = inputs.prediction_relevance[i];

        // CF-4 guard: all inputs <= 15
        let out_of_bounds = (v_dist > MAX_CLASS) as u8
            | (v_miss > MAX_CLASS) as u8
            | (v_dmg > MAX_CLASS) as u8
            | (v_thr > MAX_CLASS) as u8
            | (v_int > MAX_CLASS) as u8
            | (v_proc > MAX_CLASS) as u8
            | (v_pred > MAX_CLASS) as u8;

        // Branchless max()
        let mut score = v_miss;
        score = if v_dmg > score { v_dmg } else { score };
        score = if v_thr > score { v_thr } else { score };
        score = if v_int > score { v_int } else { score };
        score = if v_proc > score { v_proc } else { score };

        let is_crown = (score >= 13) as u8;
        let is_primary = ((score >= 9) as u8) & (1 - is_crown);
        let is_secondary = ((score >= 5) as u8) & (1 - (is_crown | is_primary));
        let is_tertiary = ((score >= 2) as u8) & (1 - (is_crown | is_primary | is_secondary));
        
        let mut class_disc: u8 = 0;
{% for row in results %}
{% if row.label == "Crown" %}
        class_disc = (is_crown * {{ row.discriminant }}) | ((1 - is_crown) * class_disc);
{% elif row.label == "Primary" %}
        class_disc = (is_primary * {{ row.discriminant }}) | ((1 - is_primary) * class_disc);
{% elif row.label == "Secondary" %}
        class_disc = (is_secondary * {{ row.discriminant }}) | ((1 - is_secondary) * class_disc);
{% elif row.label == "Tertiary" %}
        class_disc = (is_tertiary * {{ row.discriminant }}) | ((1 - is_tertiary) * class_disc);
{% else %}
        // Background sets class_disc if others are 0, initialized to 0
{% endif %}
{% endfor %}

