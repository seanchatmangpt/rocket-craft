pub fn batch_validate_motion(inputs: &MotionTraceSoA, outputs: &mut MotionOutputSoA) {
    const MAX_CLASS: u8 = 15;

    // Resolve handler mappings branchlessly via generated LUT ids
    let mut run_family_id = 255;
    let mut fire_family_id = 255;
{% for row in results %}
{% if row.label == "Run" %}
    run_family_id = {{ loop.index0 }};
{% endif %}
{% if row.handlerFn == "validate_fire_weapon" %}
    fire_family_id = {{ loop.index0 }};
{% endif %}
{% endfor %}

    for i in 0..BATCH_SIZE {
        let family = inputs.family[i];
        let heat = inputs.heat_class[i];
        let stress = inputs.stress_class[i];
        let leg = inputs.leg_damage_class[i];
        let socket = inputs.socket_available[i];

        // CF-4 Out of bounds mask
        let oob = (heat > MAX_CLASS) as u8 | (stress > MAX_CLASS) as u8 | (leg > MAX_CLASS) as u8;

        // Bitwise SIMD phase precedence masks
        let mut fire_mask: u16 = 0;
        let mut plant_mask: u16 = 0;
        let mut vent_mask: u16 = 0;
        let mut absorb_mask: u16 = 0;

        for j in 0..MAX_PHASES {
            let p = inputs.phases[i][j];
            fire_mask |= ((p == PHASE_FIRE) as u16) << j;
            plant_mask |= ((p == PHASE_PLANTFEET) as u16) << j;
            vent_mask |= ((p == PHASE_VENTHEAT) as u16) << j;
            absorb_mask |= ((p == PHASE_ABSORBRECOIL) as u16) << j;
        }

        let has_fire = (fire_mask != 0) as u8;
        let has_plant = (plant_mask != 0) as u8;
        let has_vent = (vent_mask != 0) as u8;
        let has_absorb = (absorb_mask != 0) as u8;

        let fire_idx = fire_mask.trailing_zeros();
        let plant_idx = plant_mask.trailing_zeros();
        let vent_idx = vent_mask.trailing_zeros();

        // CF-1: Fire phase requires PlantFeet BEFORE it
        let err_no_plant = has_fire & (1 - has_plant);
        let err_plant_late = has_fire & has_plant & ((plant_idx >= fire_idx) as u8);
        let err_socket = has_fire & (1 - socket);

        // CF-2: VentHeat before Fire if heat >= 12
        let high_heat = (heat >= 12) as u8;
        let err_no_vent = has_fire & high_heat & (1 - has_vent);
        let err_vent_late = has_fire & high_heat & has_vent & ((vent_idx >= fire_idx) as u8);

        let fire_refusal = err_no_plant | err_plant_late | err_socket | err_no_vent | err_vent_late;

        // Walk/Run validation
        let is_run = (family == run_family_id) as u8;
        let err_run_leg = is_run & ((leg >= 12) as u8);

        let is_fire_fam = (family == fire_family_id) as u8;

        let total_refusal = oob | (is_fire_fam & fire_refusal) | (is_run & err_run_leg);

        let delta_heat = (is_fire_fam & has_fire) * 2;
        let delta_stress = is_fire_fam & has_absorb;

        outputs.delta_heat[i] = delta_heat as i8;
        outputs.delta_stress[i] = delta_stress as i8;
        outputs.refusal_mask[i] = total_refusal;
    }
}
