PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl:  <http://www.w3.org/2002/07/owl#>
PREFIX xsd:  <http://www.w3.org/2001/XMLSchema#>
PREFIX mb:   <https://ggen.io/ontology/mechbirth/>

# -----------------------------------------------------------------------------
# SPARQL: extract_lod_classes.sparql
# Anti-Cartesian Exhaustion bounded SELECT.
# Extracts LOD class tiers ordered by discriminant for deterministic code gen.
# -----------------------------------------------------------------------------

SELECT
  ?label
  ?discriminant
  ?projectionPriority
  ?authorityRequired
  ?authorityScoreMin
  ?authorityScoreMax
  ?requiresExplicitReason
  ?explicitReasonThreshold
WHERE {
  ?cls a mb:LodClass ;
       rdfs:label ?label ;
       mb:discriminant ?discriminant ;
       mb:projectionPriority ?projectionPriority ;
       mb:authorityRequired ?authorityRequired .

  OPTIONAL { ?cls mb:authorityScoreMin ?authorityScoreMin . }
  OPTIONAL { ?cls mb:authorityScoreMax ?authorityScoreMax . }
  OPTIONAL { ?cls mb:requiresExplicitReason ?requiresExplicitReason . }
  OPTIONAL { ?cls mb:explicitReasonThreshold ?explicitReasonThreshold . }
}
ORDER BY xsd:integer(?discriminant)
