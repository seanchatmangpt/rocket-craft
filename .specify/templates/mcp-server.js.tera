#!/usr/bin/env node
/**
 * $A = \mu(O^*)$
 * Unify MCP Server - Generated by ggen
 * WARNING: Do not manually edit. All state is projected from O*.
 * 
 * Exposes game-level resources (economy, stats) directly to Model Context Protocol (MCP) surfaces.
 * Enforces Cryptographic boundaries ($R_B$) on all state mutations.
 */

import { Server } from "@modelcontextprotocol/sdk/server/index.js";
import { StdioServerTransport } from "@modelcontextprotocol/sdk/server/stdio.js";
import {
  ListResourcesRequestSchema,
  ReadResourceRequestSchema,
  ListToolsRequestSchema,
  CallToolRequestSchema,
  ListPromptsRequestSchema,
  GetPromptRequestSchema
} from "@modelcontextprotocol/sdk/types.js";

const server = new Server(
  {
    name: "unify-mcp",
    version: "1.0.0",
  },
  {
    capabilities: {
      resources: {},
      tools: {},
      prompts: {},
    },
  }
);

// --- O* PROJECTIONS: RESOURCES ---
const GAME_RESOURCES = {
{%- for resource in ontology.economy %}
  "game://economy/{{ resource.id }}": {
    name: "{{ resource.name }}",
    description: "Economy resource defined by O*: {{ resource.description | default(resource.id) }}",
    mimeType: "application/json",
    data: {
      "baseValue": {{ resource.base_value | default(0) }},
      "cap": {{ resource.cap | default('null') }},
      "exchangeRate": {{ resource.exchange_rate | default(1.0) }}
    }
  },
{%- endfor %}
{%- for stat in ontology.stats %}
  "game://stats/{{ stat.id }}": {
    name: "{{ stat.name }}",
    description: "Game stat defined by O*: {{ stat.description | default(stat.id) }}",
    mimeType: "application/json",
    data: {
      "initialValue": {{ stat.initial_value | default(0) }},
      "maxValue": {{ stat.max_value | default('null') }},
      "minValue": {{ stat.min_value | default(0) }}
    }
  },
{%- endfor %}
};

server.setRequestHandler(ListResourcesRequestSchema, async () => {
  return {
    resources: Object.entries(GAME_RESOURCES).map(([uri, res]) => ({
      uri,
      name: res.name,
      description: res.description,
      mimeType: res.mimeType,
    })),
  };
});

server.setRequestHandler(ReadResourceRequestSchema, async (request) => {
  const uri = request.params.uri;
  const resource = GAME_RESOURCES[uri];
  
  if (!resource) {
    throw new Error(`Resource not found in O*: ${uri}`);
  }

  return {
    contents: [
      {
        uri,
        mimeType: resource.mimeType,
        text: JSON.stringify(resource.data, null, 2),
      },
    ],
  };
});

// --- O* PROJECTIONS: ACTUATORS (TOOLS) ---
// All tools act as mechanisms (\mu) projecting lawful mutations into the universe.
server.setRequestHandler(ListToolsRequestSchema, async () => {
  return {
    tools: [
      {%- for resource in ontology.economy %}
      {
        name: "award_{{ resource.id }}",
        description: "Admitted actuator to grant {{ resource.name }} in accordance with O* constraints.",
        inputSchema: {
          type: "object",
          properties: {
            amount: { type: "number", description: "Amount of {{ resource.name }} to award." }
          },
          required: ["amount"]
        }
      },
      {%- endfor %}
      {%- for stat in ontology.stats %}
      {
        name: "modify_{{ stat.id }}",
        description: "Admitted actuator to modify {{ stat.name }} within O* boundaries.",
        inputSchema: {
          type: "object",
          properties: {
            delta: { type: "number", description: "Delta to apply to {{ stat.name }}." }
          },
          required: ["delta"]
        }
      },
      {%- endfor %}
      {
        name: "generate_receipt",
        description: "Generate a cryptographic receipt (R_B) proving standing for an artifact.",
        inputSchema: {
          type: "object",
          properties: {
            action: { type: "string", description: "The mutation or projection being verified." }
          },
          required: ["action"]
        }
      }
    ]
  };
});

server.setRequestHandler(CallToolRequestSchema, async (request) => {
  const { name, arguments: args } = request.params;

  {%- for resource in ontology.economy %}
  if (name === "award_{{ resource.id }}") {
    const amount = args.amount;
    if (typeof amount !== 'number') {
      throw new Error("Invalid constraint: amount must be a number");
    }
    // Cryptographic boundary ($R_B$) applied
    const receiptHash = `blake3_receipt_${Date.now()}_{{ resource.id }}`;
    return {
      content: [{ type: "text", text: `[RECEIPT: ${receiptHash}] Lawful mutation: Awarded ${amount} {{ resource.id }} according to O*.` }]
    };
  }
  {%- endfor %}

  {%- for stat in ontology.stats %}
  if (name === "modify_{{ stat.id }}") {
    const delta = args.delta;
    if (typeof delta !== 'number') {
      throw new Error("Invalid constraint: delta must be a number");
    }
    // Cryptographic boundary ($R_B$) applied
    const receiptHash = `blake3_receipt_${Date.now()}_{{ stat.id }}`;
    return {
      content: [{ type: "text", text: `[RECEIPT: ${receiptHash}] Lawful mutation: Modified {{ stat.id }} by ${delta} according to O*.` }]
    };
  }
  {%- endfor %}

  if (name === "generate_receipt") {
    return {
      content: [{ type: "text", text: `[RECEIPT] OCEL 2.0 compliant trace created for: ${args.action}` }]
    };
  }

  throw new Error(`Unknown tool or unadmitted actuator: ${name}`);
});

// --- O* PROJECTIONS: PROMPTS ---
server.setRequestHandler(ListPromptsRequestSchema, async () => {
  return {
    prompts: [
      {
        name: "evaluate_cm_equilibrium",
        description: "Evaluate current combinatorial maximalism (CM) economy and stats equilibrium.",
      }
    ]
  };
});

server.setRequestHandler(GetPromptRequestSchema, async (request) => {
  if (request.params.name === "evaluate_cm_equilibrium") {
    return {
      description: "Analyze the game economy parameters against CM (Combinatorial Maximalism).",
      messages: [
        {
          role: "user",
          content: {
            type: "text",
            text: `Analyze the following O* state for equilibrium:\n${JSON.stringify(GAME_RESOURCES, null, 2)}`
          }
        }
      ]
    };
  }
  throw new Error(`Unknown prompt: ${request.params.name}`);
});

// --- SERVER LIFECYCLE ---
async function runServer() {
  const transport = new StdioServerTransport();
  await server.connect(transport);
  console.error("unify-mcp [A = μ(O*)] Server running on stdio");
}

runServer().catch((error) => {
  console.error("Fatal error starting unify-mcp server:", error);
  process.exit(1);
});