#usda 1.0
(
    defaultPrim = "ASSET_ReferenceFabric_001"
    upAxis = "Y"
    metersPerUnit = 0.01
    doc = "Master USD assembly file for Reference Fabric Mech Asset 001"
)

def Xform "ASSET_ReferenceFabric_001" (
    kind = "assembly"
)
{
    # ---------------------------------------------------------
    # Part References (Components)
    # ---------------------------------------------------------
    def Xform "Torso" (
        references = @./SM_Torso.usda@</SM_Torso>
    )
    {}

    def Xform "Head" (
        references = @./SM_Head.usda@</SM_Head>
    )
    {}

    def Xform "WingArray_Left" (
        references = @./SM_WingArray_Left.usda@</SM_WingArray_Left>
    )
    {}

    def Xform "WingArray_Right" (
        references = @./SM_WingArray_Right.usda@</SM_WingArray_Right>
    )
    {}

    def Xform "Blade_Left" (
        references = @./SM_Blade_Left.usda@</SM_Blade_Left>
    )
    {}

    def Xform "Blade_Right" (
        references = @./SM_Blade_Right.usda@</SM_Blade_Right>
    )
    {}

    # ---------------------------------------------------------
    # Materials Scope
    # ---------------------------------------------------------
    def Scope "Materials"
    {

        def Material "M_CyanBlade"
        {
            token outputs:mtlx:surface.connect = </ASSET_ReferenceFabric_001/Materials/M_CyanBlade/OpenPBR_Surface.outputs:surface>
            
            def Shader "OpenPBR_Surface"
            {
                uniform token info:id = "ND_open_pbr_surface_surfaceshader"
                color3f inputs:base_color = (0.0, 0.8, 1.0)
                float inputs:roughness = 0.15
                float inputs:metallic = 0.9
                
                float inputs:emission = 0.8
                color3f inputs:emission_color = (0.0, 0.8, 1.0)
                
                token outputs:surface
            }
        }

        def Material "M_DarkFrame"
        {
            token outputs:mtlx:surface.connect = </ASSET_ReferenceFabric_001/Materials/M_DarkFrame/OpenPBR_Surface.outputs:surface>
            
            def Shader "OpenPBR_Surface"
            {
                uniform token info:id = "ND_open_pbr_surface_surfaceshader"
                color3f inputs:base_color = (0.15, 0.15, 0.18)
                float inputs:roughness = 0.6
                float inputs:metallic = 0.5
                
                token outputs:surface
            }
        }

        def Material "M_GoldVisor"
        {
            token outputs:mtlx:surface.connect = </ASSET_ReferenceFabric_001/Materials/M_GoldVisor/OpenPBR_Surface.outputs:surface>
            
            def Shader "OpenPBR_Surface"
            {
                uniform token info:id = "ND_open_pbr_surface_surfaceshader"
                color3f inputs:base_color = (1.0, 0.8, 0.0)
                float inputs:roughness = 0.1
                float inputs:metallic = 0.9
                
                float inputs:emission = 0.5
                color3f inputs:emission_color = (1.0, 0.8, 0.0)
                
                token outputs:surface
            }
        }

        def Material "M_WhiteArmor"
        {
            token outputs:mtlx:surface.connect = </ASSET_ReferenceFabric_001/Materials/M_WhiteArmor/OpenPBR_Surface.outputs:surface>
            
            def Shader "OpenPBR_Surface"
            {
                uniform token info:id = "ND_open_pbr_surface_surfaceshader"
                color3f inputs:base_color = (1.0, 1.0, 1.0)
                float inputs:roughness = 0.4
                float inputs:metallic = 0
                
                token outputs:surface
            }
        }

    }
}