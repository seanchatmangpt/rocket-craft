<?xml version="1.0"?>
<materialx version="1.38">

  <!-- Material: M_CyanBlade -->
  <open_pbr_surface name="M_CyanBlade_shader" type="surfaceshader">
    <input name="base_color" type="color3" value="0.0 0.8 1.0" />
    <input name="roughness" type="float" value="0.15" />
    <input name="specular_roughness" type="float" value="0.15" />
    <input name="metalness" type="float" value="0.9" />
    
    <input name="emission" type="float" value="0.8" />
    <input name="emission_color" type="color3" value="0.0 0.8 1.0" />
    
  </open_pbr_surface>
  <surfacematerial name="M_CyanBlade" type="material">
    <input name="surfaceshader" type="surfaceshader" nodename="M_CyanBlade_shader" />
  </surfacematerial>

  <!-- Material: M_DarkFrame -->
  <open_pbr_surface name="M_DarkFrame_shader" type="surfaceshader">
    <input name="base_color" type="color3" value="0.15 0.15 0.18" />
    <input name="roughness" type="float" value="0.6" />
    <input name="specular_roughness" type="float" value="0.6" />
    <input name="metalness" type="float" value="0.5" />
    
  </open_pbr_surface>
  <surfacematerial name="M_DarkFrame" type="material">
    <input name="surfaceshader" type="surfaceshader" nodename="M_DarkFrame_shader" />
  </surfacematerial>

  <!-- Material: M_GoldVisor -->
  <open_pbr_surface name="M_GoldVisor_shader" type="surfaceshader">
    <input name="base_color" type="color3" value="1.0 0.8 0.0" />
    <input name="roughness" type="float" value="0.1" />
    <input name="specular_roughness" type="float" value="0.1" />
    <input name="metalness" type="float" value="0.9" />
    
    <input name="emission" type="float" value="0.5" />
    <input name="emission_color" type="color3" value="1.0 0.8 0.0" />
    
  </open_pbr_surface>
  <surfacematerial name="M_GoldVisor" type="material">
    <input name="surfaceshader" type="surfaceshader" nodename="M_GoldVisor_shader" />
  </surfacematerial>

  <!-- Material: M_WhiteArmor -->
  <open_pbr_surface name="M_WhiteArmor_shader" type="surfaceshader">
    <input name="base_color" type="color3" value="1.0 1.0 1.0" />
    <input name="roughness" type="float" value="0.4" />
    <input name="specular_roughness" type="float" value="0.4" />
    <input name="metalness" type="float" value="0" />
    
  </open_pbr_surface>
  <surfacematerial name="M_WhiteArmor" type="material">
    <input name="surfaceshader" type="surfaceshader" nodename="M_WhiteArmor_shader" />
  </surfacematerial>

</materialx>