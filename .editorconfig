# http://editorconfig.org
root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{cpp,h,cs}]
indent_style = tab
tab_width = 4

[*.js]
indent_style = space
indent_size = 2

[*.ini]
indent_style = space
indent_size = 4
