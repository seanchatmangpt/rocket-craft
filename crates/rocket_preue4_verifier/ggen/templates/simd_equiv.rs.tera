use crate::error::RefusalReason;

/// Lane width: {{ lane_width }} u8 lanes = 128-bit register floor.
/// Sourced from mb:SimdLaneWidth mb:value.
const LANE_WIDTH: usize = {{ lane_width }};

/// Process `n` elements in chunks of `LANE_WIDTH` lanes using chunked arithmetic.
///
/// Semantically mirrors a 128-bit SIMD kernel's data flow pattern.
/// Returns `Err(InvalidAuthorityClass)` if input slice lengths are mismatched.
///
/// **RESIDUAL GC-MECHBIRTH-003**: Replace inner loop with `std::simd` or SIMDe FFI.
pub fn batch_update_damage_simd_equiv(
    heat: &[u8],
    stress: &[u8],
    socket_health: &[u8],
    damage: &mut [u8],
) -> Result<(), RefusalReason> {
    let n = heat.len();
    if stress.len() != n || socket_health.len() != n || damage.len() != n {
        return Err(RefusalReason::InvalidAuthorityClass {
            field: "simd input lengths".into(),
            class: 0,
        });
    }

    // {{ lane_width }}-lane chunked pass — mirrors SIMD register width
    let mut i = 0usize;
    while i + LANE_WIDTH <= n {
        // Unrolled: {{ lane_width }} lanes per iteration
        for j in 0..LANE_WIDTH {
            damage[i + j] = crate::transitions::scalar_failure_risk(
                heat[i + j],
                stress[i + j],
                socket_health[i + j],
            );
        }
        i += LANE_WIDTH;
    }

    // Remainder lanes (tail < LANE_WIDTH)
    while i < n {
        damage[i] = crate::transitions::scalar_failure_risk(
            heat[i], stress[i], socket_health[i],
        );
        i += 1;
    }

    Ok(())
}

/// Verifies that the SIMD-equivalent path produces bit-identical output to scalar.
///
/// van der Aalst conformance: every (heat[i], stress[i], socket_health[i]) triple
/// must produce identical tokens in both the scalar trace and SIMD-shaped trace.
///
/// Returns `Err(SimdScalarDivergence { index })` at the first divergent lane.
pub fn verify_simd_scalar_equivalence(
    heat: &[u8],
    stress: &[u8],
    socket_health: &[u8],
) -> Result<(), RefusalReason> {
    let n = heat.len();
    let mut scalar_out = vec![0u8; n];
    let mut simd_out   = vec![0u8; n];

    for i in 0..n {
        scalar_out[i] = crate::transitions::scalar_failure_risk(
            heat[i], stress[i], socket_health[i],
        );
    }

    batch_update_damage_simd_equiv(heat, stress, socket_health, &mut simd_out)?;

    for i in 0..n {
        if scalar_out[i] != simd_out[i] {
            return Err(RefusalReason::SimdScalarDivergence { index: i });
        }
    }

    Ok(())
}
